<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#030708">

    <androidx.camera.view.PreviewView
        android:id="@+id/previewView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.minos.hud.HUDOverlayView
        android:id="@+id/hudOverlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Top System Telemetry -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:orientation="vertical"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:text="PANOPTICORE // SENSOR MATRIX"
            android:textColor="#00FF66"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:text="SYS.STATUS // ACTIVE INTERCEPT"
            android:textColor="#00E5FF"
            android:textSize="10sp" />

        <TextView
            android:id="@+id/fpsText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="FPS: 0"
            android:textColor="#00FF66"
            android:textSize="10sp"
            android:fontFamily="monospace" />

        <TextView
            android:id="@+id/inferenceText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="INF: 0ms"
            android:textColor="#00FF66"
            android:textSize="10sp"
            android:fontFamily="monospace" />
    </LinearLayout>

    <!-- Floating Mag-Track Sub-Windows -->
    <include
        android:id="@+id/magTrack01"
        layout="@layout/item_detection_dossier"
        android:layout_width="160dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="120dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <include
        android:id="@+id/magTrack02"
        layout="@layout/item_detection_dossier"
        android:layout_width="160dp"
        android:layout_height="wrap_content"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="80dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <include
        android:id="@+id/magTrack03"
        layout="@layout/item_detection_dossier"
        android:layout_width="160dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginBottom="350dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <include
        android:id="@+id/magTrack04"
        layout="@layout/item_detection_dossier"
        android:layout_width="160dp"
        android:layout_height="wrap_content"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="350dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Base Terminal Management Panel -->
    <LinearLayout
        android:id="@+id/terminalPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#ED050C14"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Tab Selector -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:background="#02080F"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tabGeolog"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="GEOLOG PANEL"
                android:textColor="#00FF66"
                android:fontFamily="monospace"
                android:textSize="12sp"
                android:background="?attr/selectableItemBackground" />

            <TextView
                android:id="@+id/tabGps"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="GPS TACTICAL MAP"
                android:textColor="#00E5FF"
                android:fontFamily="monospace"
                android:textSize="12sp"
                android:background="?attr/selectableItemBackground" />

            <TextView
                android:id="@+id/tabClose"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="TOOLS CLOSE"
                android:textColor="#FFA500"
                android:fontFamily="monospace"
                android:textSize="12sp"
                android:background="?attr/selectableItemBackground" />
        </LinearLayout>

        <!-- Dynamic Content Area -->
        <ScrollView
            android:id="@+id/panelContent"
            android:layout_width="match_parent"
            android:layout_height="250dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="TRACKING + SENSOR OVERLAYS"
                    android:textColor="#FFA500"
                    android:fontFamily="monospace"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:scrollbars="none">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnMotionArray"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="8dp"
                            android:text="MOTION ARRAY\nON"
                            android:textColor="#00FF66"
                            app:strokeColor="#00FF66" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnAutoLock"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="8dp"
                            android:text="AUTO TARGET\nLOCK"
                            android:textColor="#00FF66"
                            app:strokeColor="#00FF66" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnRadarSweep"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="RADAR SWEEP\nON"
                            android:textColor="#00FF66"
                            app:strokeColor="#00FF66" />
                    </LinearLayout>
                </HorizontalScrollView>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="VISUAL RENDER + TARGET VIEW"
                    android:textColor="#FFA500"
                    android:fontFamily="monospace"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="4dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnRenderClassic"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:text="RENDER\nCLASSIC"
                        android:textColor="#00E5FF"
                        app:strokeColor="#00E5FF" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnTargetBig"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:text="TARGET\nBIG"
                        android:textColor="#00E5FF"
                        app:strokeColor="#00E5FF" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnTargetNormal"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="TARGET\nNORMAL"
                        android:textColor="#00E5FF"
                        app:strokeColor="#00E5FF" />
                </LinearLayout>

                <TextView
                    android:id="@+id/txtZoomLabel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="DIGITAL CAMERA ZOOM: 8"
                    android:textColor="#00FF66"
                    android:fontFamily="monospace"
                    android:textSize="14sp" />

                <SeekBar
                    android:id="@+id/seekBarZoom"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="16"
                    android:progress="8"
                    android:progressTint="#00FF66"
                    android:thumbTint="#FFFFFF" />

                <TextView
                    android:id="@+id/txtMotionLabel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="MOTION SENSITIVITY: 36"
                    android:textColor="#00FF66"
                    android:fontFamily="monospace"
                    android:textSize="14sp" />

                <SeekBar
                    android:id="@+id/seekBarMotion"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="100"
                    android:progress="36"
                    android:progressTint="#00FF66"
                    android:thumbTint="#FFFFFF" />
            </LinearLayout>
        </ScrollView>
    </LinearLayout>

    <!-- Inclusion of Dossier Overlay -->
    <include layout="@layout/layout_dossier_overlay" />

    <!-- Inclusion of Settings Overlay -->
    <include layout="@layout/layout_settings_overlay" />

</androidx.constraintlayout.widget.ConstraintLayout>
