<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <androidx.camera.view.PreviewView
        android:id="@+id/previewView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.minos.hud.HUDOverlayView
        android:id="@+id/hudOverlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Top Status Bar -->
    <LinearLayout
        android:id="@+id/telemetryContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:background="#A60D1527"
        android:orientation="vertical"
        android:padding="8dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:text="SYS.LOG // PANOPTICORE_V4.2"
            android:textColor="#00E5FF"
            android:textSize="10sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:text="STATUS // TARGET ACQUISITION ACTIVE"
            android:textColor="#00FF66"
            android:textSize="10sp" />

        <TextView
            android:id="@+id/fpsText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="FPS: 0"
            android:textColor="#00FF66"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/inferenceText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="INF: 0ms"
            android:textColor="#00FF66"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Bottom Control Panel -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:scrollbars="none"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnToggleDetection"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:text="SCAN: ON"
                android:textColor="#00FF66"
                app:strokeColor="#00FF66" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCycleReticle"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:text="RETICLE"
                android:textColor="#00FF66"
                app:strokeColor="#00FF66" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnToggleTorch"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:text="TORCH"
                android:textColor="#00FF66"
                app:strokeColor="#00FF66" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnZoom"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:text="ZOOM: 1X"
                android:textColor="#00FF66"
                app:strokeColor="#00FF66" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSwitchModel"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MODEL: NANO"
                android:textColor="#00FF66"
                app:strokeColor="#00FF66" />

        </LinearLayout>
    </HorizontalScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
