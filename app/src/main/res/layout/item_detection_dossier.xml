<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@drawable/bg_cyber_card"
    android:orientation="horizontal"
    android:padding="12dp">

    <ImageView
        android:id="@+id/imgDetectionThumb"
        android:layout_width="70dp"
        android:layout_height="70dp"
        android:background="#0D1527"
        android:scaleType="centerCrop"
        android:src="@drawable/ic_launcher_foreground" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/txtDetectionLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:text="TARGET: UNKNOWN"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtDetectionIndex"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:text="INDEX: LOCAL_DATABASE"
            android:textColor="#00E5FF"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/txtDetectionConfidence"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:fontFamily="monospace"
            android:text="CORRELATION: 0%"
            android:textColor="#00FF66"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_vertical"
        android:background="@drawable/bg_cyber_button"
        android:fontFamily="monospace"
        android:paddingHorizontal="12dp"
        android:paddingVertical="4dp"
        android:text="FILE"
        android:textColor="#00FF66"
        android:textSize="12sp"
        android:textStyle="bold" />

</LinearLayout>